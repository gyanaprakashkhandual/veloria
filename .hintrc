{
  "extends": [
    "development"
  ],
  "hints": {
    "button-type": "off",
    "axe/name-role-value": "off",
    "no-inline-styles": "off",
    "axe/forms": "off",
    "axe/aria": "off",
    "typescript-config/is-valid": "off",
    "typescript-config/strict": "off",
    "typescript-config/consistent-casing": "off"
  },
  "browserslist": [
    "defaults",
    "not ie 11",
    "not ios_saf <= 18.3",
    "not safari <= 18.3",
    "not and_chr <= 134",
    "not chrome <= 135",
    "not edge <= 134",
    "not opera <= 117",
    "not samsung <= 27"
  ]
}